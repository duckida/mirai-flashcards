# ============================================
# AI Flashcard Quizzer - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local

# --------------------------------------------
# Application Configuration
# --------------------------------------------
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
SESSION_SECRET=generate-a-random-secret-here
FRONTEND_URL=http://localhost:3001

# --------------------------------------------
# Civic.ai Authentication (OAuth)
# --------------------------------------------
CIVIC_CLIENT_ID=your-civic-client-id
CIVIC_CLIENT_SECRET=your-civic-client-secret
CIVIC_CALLBACK_URL=http://localhost:3000/api/auth/callback
CIVIC_AUTH_URL=https://auth.civic.ai/oauth/authorize
CIVIC_TOKEN_URL=https://auth.civic.ai/oauth/token
CIVIC_USER_INFO_URL=https://auth.civic.ai/oauth/userinfo

# --------------------------------------------
# ElevenLabs Agents (Conversational AI)
# --------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_AGENT_ID=your-elevenlabs-agent-id

# --------------------------------------------
# Gemini Voice Provider
# --------------------------------------------
GEMINI_API_KEY=your-gemini-api-key
GEMINI_PROJECT_ID=your-gemini-project-id

# --------------------------------------------
# Voice Provider Configuration
# --------------------------------------------
# Enable Firebase Remote Config for dynamic provider selection
FIREBASE_REMOTE_CONFIG_ENABLED=false
# Default provider when Remote Config is disabled (elevenlabs or gemini)
VOICE_PROVIDER_DEFAULT=elevenlabs

# --------------------------------------------
# Canva MCP Integration (via Civic.ai MCP Hub)
# --------------------------------------------
CIVIC_MCP_HUB_URL=https://hub.mcp.civic.com
CIVIC_MCP_API_KEY=your-civic-mcp-api-key

# --------------------------------------------
# Vercel AI Gateway Configuration
# --------------------------------------------
AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v3/ai
VISION_MODEL=alibaba/qwen3.5-flash
IMAGE_GENERATION_MODEL=google/gemini-2.5-flash-image
CLASSIFICATION_MODEL=alibaba/qwen3.5-flash

# --------------------------------------------
# Firebase / Firestore Configuration
# --------------------------------------------
# Paste your Firebase service account JSON here (single line)
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"..."}'

NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# --------------------------------------------
# Rate Limiting and Security
# --------------------------------------------
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=3600000
MAX_UPLOAD_SIZE=20971520
ALLOWED_IMAGE_FORMATS=image/jpeg,image/png,image/webp

# --------------------------------------------
# Vercel Storage (Blob Storage)
# --------------------------------------------
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token
